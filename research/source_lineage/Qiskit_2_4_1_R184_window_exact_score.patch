+        let score = <ActiveFixedExactF64Score as vf2::Vf2Score>::combine(&left.0, &right.0);
+        let used = match &score {
+            ActiveFixedExactF64Score::Finite { used, .. } => usize::from(*used),
+            ActiveFixedExactF64Score::PositiveInfinity => 0,
+        };
+        r182_update_counters(|counters| {
+            counters.destination_zeroed_limb_count += FIXED_EXACT_F64_LIMBS as u64;
+            counters.arithmetic_limb_visit_count += left_used.max(right_used) as u64;
+            counters.carry_extension_count += u64::from(used > left_used.max(right_used));
+            counters.maximum_used_limb_count = counters.maximum_used_limb_count.max(used as u64);
+        });
+        Self(score)
+    }
+
+    fn id() -> Self {
+        r182_update_counters(|counters| {
+            counters.destination_zeroed_limb_count += FIXED_EXACT_F64_LIMBS as u64;
+        });
+        Self(<ActiveFixedExactF64Score as vf2::Vf2Score>::id())
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        left.cmp(right)
+    }
+}
