+            counters.r183_destination_initialized_limb_count += FIXED_EXACT_F64_LIMBS as u64;
+            counters.r183_full_width_destination_count += 1;
+        });
+        Self(<ActiveFixedExactF64Score as vf2::Vf2Score>::id())
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        if let (
+            ActiveFixedExactF64Score::Finite {
+                limbs: left_limbs,
+                used: left_used,
+            },
+            ActiveFixedExactF64Score::Finite {
+                limbs: right_limbs,
+                used: right_used,
+            },
+        ) = (&left.0, &right.0)
+        {
+            let visits = if left_used == right_used {
+                r182_fixed_comparison_visits(left_limbs, right_limbs, usize::from(*left_used))
+            } else {
+                0
+            } as u64;
+            r182_update_counters(|counters| counters.comparison_limb_visit_count += visits);
+        }
+        left.0.cmp(&right.0)
+    }
+}
