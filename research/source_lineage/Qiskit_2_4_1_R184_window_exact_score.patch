+fn trace_graph_from_interactions(graph: &Graph<usize, usize>) -> Graph<TraceWeight, TraceWeight> {
+    let mut out = Graph::with_capacity(graph.node_count(), graph.edge_count());
+    for node in graph.node_indices() {
+        out.add_node(TraceWeight {
+            value: *graph.node_weight(node).expect("interaction node exists") as f64,
+            label: format!("v{}", node.index()),
+        });
+    }
+    for edge in graph.edge_references() {
+        out.add_edge(
+            edge.source(),
+            edge.target(),
+            TraceWeight {
+                value: *edge.weight() as f64,
+                label: format!("v{}->v{}", edge.source().index(), edge.target().index()),
+            },
+        );
+    }
+    out
+}
+
+fn trace_graph_from_coupling(graph: &Graph<f64, f64>) -> Graph<TraceWeight, TraceWeight> {
+    let mut out = Graph::with_capacity(graph.node_count(), graph.edge_count());
+    for node in graph.node_indices() {
+        out.add_node(TraceWeight {
+            value: *graph.node_weight(node).expect("coupling node exists"),
+            label: format!("p{}", node.index()),
+        });
+    }
+    for edge in graph.edge_references() {
+        out.add_edge(
+            edge.source(),
+            edge.target(),
+            TraceWeight {
+                value: *edge.weight(),
+                label: format!("p{}->p{}", edge.source().index(), edge.target().index()),
+            },
+        );
+    }
+    out
+}
+
+fn trace_score_identity_layout(
+    interactions: &Graph<TraceWeight, TraceWeight>,
+    coupling: &Graph<TraceWeight, TraceWeight>,
+    events: Rc<RefCell<Vec<ScoreTraceEvent>>>,
+) -> Option<TraceScore> {
+    let mut score = TraceScore::zero(events.clone());
+    for node in interactions.node_indices() {
+        let needle = interactions.node_weight(node)?;
+        let haystack = coupling.node_weight(node)?;
+        score = TraceScore::combine(
+            &score,
+            &TraceScore::leaf(
+                needle.value * haystack.value,
+                format!("node:{}=>{}", needle.label, haystack.label),
+                events.clone(),
+            ),
+        );
+    }
+    for edge in interactions.edge_references() {
+        let haystack = coupling
+            .edges_connecting(edge.source(), edge.target())
+            .next()?;
+        score = TraceScore::combine(
+            &score,
+            &TraceScore::leaf(
+                edge.weight().value * haystack.weight().value,
+                format!("edge:{}=>{}", edge.weight().label, haystack.weight().label),
+                events.clone(),
+            ),
+        );
+    }
+    Some(score)
+}
