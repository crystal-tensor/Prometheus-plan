+#[cfg(test)]
+mod r176_fixed_exact_score_tests {
+    use super::*;
+
+    fn fixed_as_biguint(score: &FixedExactF64Score) -> Option<BigUint> {
+        match score {
+            FixedExactF64Score::PositiveInfinity => None,
+            FixedExactF64Score::Finite(limbs) => Some(
+                limbs
+                    .iter()
+                    .enumerate()
+                    .fold(BigUint::from(0u8), |sum, (index, limb)| {
+                        sum + (BigUint::from(*limb) << (index * u64::BITS as usize))
+                    }),
+            ),
+        }
+    }
+
+    fn arbitrary_as_biguint(score: &ExactF64Score) -> Option<&BigUint> {
+        match score {
+            ExactF64Score::PositiveInfinity => None,
+            ExactF64Score::Finite(value) => Some(value),
+        }
+    }
+
+    #[test]
+    fn fixed_binary64_decode_matches_biguint() {
+        let samples = [
+            0.0,
+            -0.0,
+            f64::from_bits(1),
+            f64::from_bits((1u64 << 52) - 1),
+            f64::MIN_POSITIVE,
+            0.1,
+            1.0,
+            f64::MAX,
+        ];
+        for value in samples {
+            let fixed = FixedExactF64Score::from_f64(value);
+            let arbitrary = ExactF64Score::from_f64(value);
+            assert_eq!(
+                fixed_as_biguint(&fixed).as_ref(),
+                arbitrary_as_biguint(&arbitrary)
+            );
+        }
+    }
+
+    #[test]
+    fn fixed_addition_and_order_match_biguint() {
+        let values = [f64::from_bits(1), 0.1, 0.2, 0.3, 1.0, f64::MAX];
+        for left_value in values {
+            for right_value in values {
+                let fixed_left = FixedExactF64Score::from_f64(left_value);
+                let fixed_right = FixedExactF64Score::from_f64(right_value);
+                let fixed_sum =
+                    <FixedExactF64Score as vf2::Vf2Score>::combine(&fixed_left, &fixed_right);
+                let arbitrary_left = ExactF64Score::from_f64(left_value);
+                let arbitrary_right = ExactF64Score::from_f64(right_value);
+                let arbitrary_sum =
+                    <ExactF64Score as vf2::Vf2Score>::combine(&arbitrary_left, &arbitrary_right);
+                assert_eq!(
+                    fixed_as_biguint(&fixed_sum).as_ref(),
+                    arbitrary_as_biguint(&arbitrary_sum)
+                );
+                assert_eq!(
+                    fixed_left.cmp(&fixed_right),
+                    arbitrary_left.cmp(&arbitrary_right)
+                );
+            }
+        }
+    }
+
+    #[test]
+    fn infinity_is_larger_than_every_finite_score() {
+        let infinity = FixedExactF64Score::from_f64(f64::INFINITY);
+        let maximum = FixedExactF64Score::from_f64(f64::MAX);
+        assert!(infinity > maximum);
+        assert_eq!(
+            <FixedExactF64Score as vf2::Vf2Score>::combine(&infinity, &maximum),
+            infinity
+        );
+    }
+}
