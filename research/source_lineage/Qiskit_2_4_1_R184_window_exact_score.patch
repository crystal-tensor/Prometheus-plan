+#[pyfunction]
+#[pyo3(signature = (dag, target, config, *, strict_direction=false, operation_order="native"))]
+pub fn vf2_layout_pass_average_score_traced(
+    dag: &DAGCircuit,
+    target: &Target,
+    config: &Vf2PassConfiguration,
+    strict_direction: bool,
+    operation_order: &str,
+) -> PyResult<(Vf2PassReturn, Vec<ScoreTraceEvent>, Vec<ErrorMapTraceRow>)> {
+    let add_interaction = |count: &mut usize, _: &PackedInstruction, repeats: usize| {
+        *count += repeats;
+        true
+    };
+    let interactions = VirtualInteractions::from_dag(dag, add_interaction)?
+        .expect("weighting function is infallible");
+    let Some((error_map, error_map_trace)) = build_average_error_map_traced(
+        target,
+        match operation_order {
+            "native" => ErrorMapOperationOrder::Native,
+            "ascending" => ErrorMapOperationOrder::Ascending,
+            "descending" => ErrorMapOperationOrder::Descending,
+            value => {
+                return Err(pyo3::exceptions::PyValueError::new_err(format!(
+                    "invalid ErrorMap operation order: {value}"
+                )));
+            }
+        },
+    ) else {
+        return Ok((Vf2PassReturn::NoSolution, Vec::new(), Vec::new()));
+    };
+    let Some(mut coupling_graph) = build_average_coupling_map(target, &error_map) else {
+        return Ok((Vf2PassReturn::NoSolution, Vec::new(), error_map_trace));
+    };
+    if !strict_direction {
+        loosen_directionality(&mut coupling_graph);
+    }
+
+    let events = Rc::new(RefCell::new(Vec::new()));
+    let trace_interactions = trace_graph_from_interactions(&interactions.graph);
+    let trace_coupling = trace_graph_from_coupling(&coupling_graph);
+    let node_score_events = events.clone();
+    let node_score = move |count: &TraceWeight, err: &TraceWeight| {
+        Ok::<TraceScore, Infallible>(TraceScore::leaf(
+            count.value * err.value,
+            format!("node:{}=>{}", count.label, err.label),
+            node_score_events.clone(),
+        ))
+    };
+    let edge_score_events = events.clone();
+    let edge_score = move |count: &TraceWeight, err: &TraceWeight| {
+        Ok::<TraceScore, Infallible>(TraceScore::leaf(
+            count.value * err.value,
+            format!("edge:{}=>{}", count.label, err.label),
+            edge_score_events.clone(),
+        ))
+    };
+    let best_score = if config.score_initial_layout {
+        trace_score_identity_layout(&trace_interactions, &trace_coupling, events.clone())
+    } else {
+        None
+    };
+    let num_physical_qubits = coupling_graph.node_count();
+    let mut coupling_qubits = (0..num_physical_qubits)
+        .map(|k| PhysicalQubit::new(k as u32))
+        .collect::<Vec<_>>();
+    if let Some(seed) = config.shuffle_seed {
+        coupling_qubits.shuffle(&mut Pcg64Mcg::seed_from_u64(seed));
+        let order = coupling_qubits
+            .iter()
+            .map(|qubit| NodeIndex::new(qubit.index()))
+            .collect::<Vec<_>>();
+        coupling_graph = vf2::reorder_nodes(&coupling_graph, &order);
+    }
+    let trace_coupling = trace_graph_from_coupling(&coupling_graph);
+    let vf2 = vf2::Vf2::new(&trace_interactions, &trace_coupling, vf2::Problem::Subgraph)
+        .with_scoring(node_score, edge_score)
+        .with_restriction(vf2::Restriction::Decreasing(best_score))
+        .with_vf2pp_ordering();
+    let start_time = Instant::now();
+    let mut times_up = false;
+    let mut trials: usize = 0;
+    let max_trials = config
+        .max_trials
+        .unwrap_or_else(|| 15 + vf2.needle().edge_count().max(vf2.haystack().edge_count()));
+    let time_limit = config.time_limit.unwrap_or(f64::INFINITY);
+    let mut can_continue = || {
+        if times_up {
+            return false;
+        }
+        times_up = start_time.elapsed().as_secs_f64() >= time_limit;
+        trials += 1;
+        max_trials == 0 || trials <= max_trials
+    };
+    let mut vf2 = vf2.with_call_limit(config.call_limit.0).into_iter();
+    let Some(first) = vf2.next() else {
+        let output = if config.score_initial_layout {
+            Vf2PassReturn::NoImprovement
+        } else {
+            Vf2PassReturn::NoSolution
+        };
+        return Ok((output, events.borrow().clone(), error_map_trace));
+    };
+    let (mut mapping, mut score) = first.expect("error is infallible");
+    let mut candidate_index = 0usize;
+    let mut record_candidate =
+        |candidate_mapping: &IndexMap<NodeIndex, NodeIndex, ::ahash::RandomState>,
+         candidate_score: &TraceScore| {
+            let mapping_terms = candidate_mapping
+                .iter()
+                .map(|(virtual_qubit, physical_qubit)| {
+                    format!("v{}->p{}", virtual_qubit.index(), physical_qubit.index())
+                })
+                .collect::<Vec<_>>()
+                .join("|");
+            events.borrow_mut().push((
+                "candidate".to_string(),
+                candidate_score.value.to_bits(),
+                0,
+                0,
+                mapping_terms,
+                candidate_score.terms.clone(),
+                format!(
+                    "yielded_by_vf2;candidate_index={};leaves={}",
+                    candidate_index,
+                    encode_score_leaves(&candidate_score.leaves)
+                ),
+            ));
+            candidate_index += 1;
+        };
+    record_candidate(&mapping, &score);
+    if can_continue() {
+        vf2.call_limit = config.call_limit.1;
+        while can_continue() {
+            let Some(next) = vf2.next() else {
+                break;
+            };
+            let (new_mapping, new_score) = next.expect("error is infallible");
+            record_candidate(&new_mapping, &new_score);
+            mapping = new_mapping;
+            score = new_score;
+        }
+    }
+    let mapping_terms = mapping
+        .iter()
+        .map(|(virtual_qubit, physical_qubit)| {
+            format!("v{}->p{}", virtual_qubit.index(), physical_qubit.index())
+        })
+        .collect::<Vec<_>>()
+        .join("|");
+    events.borrow_mut().push((
+        "candidate".to_string(),
+        score.value.to_bits(),
+        0,
+        0,
+        mapping_terms,
+        score.terms.clone(),
+        format!(
+            "returned_by_minimize_vf2;leaves={}",
+            encode_score_leaves(&score.leaves)
+        ),
+    ));
+    let mapping = mapping
+        .iter()
+        .map(|(k, v)| (interactions.nodes[k.index()], coupling_qubits[v.index()]))
+        .collect();
+    let output = match map_free_qubits(num_physical_qubits, interactions, mapping, &error_map) {
+        Some(mapping) => Vf2PassReturn::Solution(mapping),
+        None => Vf2PassReturn::NoSolution,
+    };
+    Ok((output, events.borrow().clone(), error_map_trace))
+}
