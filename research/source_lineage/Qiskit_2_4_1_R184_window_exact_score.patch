+    #[test]
+    fn r183_counter_pair_isolated_unused_tail_initialization() {
+        r182_reset_counters();
+        let active_left = R183InstrumentedActiveFixedExactF64Score::from_f64(0.1);
+        let active_right = R183InstrumentedActiveFixedExactF64Score::from_f64(0.2);
+        let active_sum =
+            R183InstrumentedActiveFixedExactF64Score::combine(&active_left, &active_right);
+        let _ = R183InstrumentedActiveFixedExactF64Score::cmp(&active_sum, &active_left);
+        let active = r182_take_counters();
+
+        r182_reset_counters();
+        let prefix_left = R183InstrumentedPrefixInitializedExactF64Score::from_f64(0.1);
+        let prefix_right = R183InstrumentedPrefixInitializedExactF64Score::from_f64(0.2);
+        let prefix_sum =
+            R183InstrumentedPrefixInitializedExactF64Score::combine(&prefix_left, &prefix_right);
+        let _ = R183InstrumentedPrefixInitializedExactF64Score::cmp(&prefix_sum, &prefix_left);
+        let prefix = r182_take_counters();
+
+        assert_eq!(
+            active.leaf_construction_count,
+            prefix.leaf_construction_count
+        );
+        assert_eq!(
+            active.arithmetic_limb_visit_count,
+            prefix.arithmetic_limb_visit_count
+        );
+        assert_eq!(
+            active.comparison_limb_visit_count,
+            prefix.comparison_limb_visit_count
+        );
+        assert_eq!(active.carry_extension_count, prefix.carry_extension_count);
+        assert_eq!(
+            active.maximum_used_limb_count,
+            prefix.maximum_used_limb_count
+        );
+        assert!(
+            prefix.r183_destination_initialized_limb_count
+                < active.r183_destination_initialized_limb_count
+        );
+        assert!(active.r183_full_width_destination_count > 0);
+        assert_eq!(prefix.r183_full_width_destination_count, 0);
+        assert_eq!(
+            std::mem::size_of::<PrefixInitializedExactF64Score>(),
+            std::mem::size_of::<ActiveFixedExactF64Score>()
+        );
+    }
+}
