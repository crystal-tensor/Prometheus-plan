+#[cfg(test)]
+mod r184_window_exact_score_tests {
+    use super::*;
+
+    fn arbitrary_as_biguint(score: &ExactF64Score) -> Option<&BigUint> {
+        match score {
+            ExactF64Score::PositiveInfinity => None,
+            ExactF64Score::Finite(value) => Some(value),
+        }
+    }
+
+    #[test]
+    fn window_binary64_decode_matches_biguint() {
+        let samples = [
+            0.0,
+            -0.0,
+            f64::from_bits(1),
+            f64::from_bits((1u64 << 52) - 1),
+            f64::MIN_POSITIVE,
+            0.1,
+            1.0,
+            f64::MAX,
+        ];
+        for value in samples {
+            let window = WindowExactF64Score::from_f64(value);
+            let arbitrary = ExactF64Score::from_f64(value);
+            assert_eq!(
+                window.to_biguint().as_ref(),
+                arbitrary_as_biguint(&arbitrary)
+            );
+        }
+    }
+
+    #[test]
+    fn window_addition_and_order_match_biguint_over_deterministic_pressure() {
+        let mut state = 0x1840_5eed_cafe_babe_u64;
+        for _ in 0..4096 {
+            state = state
+                .wrapping_mul(6364136223846793005)
+                .wrapping_add(1442695040888963407);
+            let left_bits = state & 0x7fef_ffff_ffff_ffff;
+            state = state
+                .wrapping_mul(6364136223846793005)
+                .wrapping_add(1442695040888963407);
+            let right_bits = state & 0x7fef_ffff_ffff_ffff;
+            let left_value = f64::from_bits(left_bits);
+            let right_value = f64::from_bits(right_bits);
+            let window_left = WindowExactF64Score::from_f64(left_value);
+            let window_right = WindowExactF64Score::from_f64(right_value);
+            let window_sum =
+                <WindowExactF64Score as vf2::Vf2Score>::combine(&window_left, &window_right);
+            let arbitrary_left = ExactF64Score::from_f64(left_value);
+            let arbitrary_right = ExactF64Score::from_f64(right_value);
+            let arbitrary_sum =
+                <ExactF64Score as vf2::Vf2Score>::combine(&arbitrary_left, &arbitrary_right);
+            assert_eq!(
+                window_sum.to_biguint().as_ref(),
+                arbitrary_as_biguint(&arbitrary_sum)
+            );
+            assert_eq!(
+                window_left.cmp(&window_right),
+                arbitrary_left.cmp(&arbitrary_right)
+            );
+        }
+    }
+
+    #[test]
+    fn window_uses_compact_common_path_and_exact_wide_fallback() {
+        let compact = <WindowExactF64Score as vf2::Vf2Score>::combine(
+            &WindowExactF64Score::from_f64(0.1),
+            &WindowExactF64Score::from_f64(0.2),
+        );
+        assert!(matches!(compact, WindowExactF64Score::Finite { .. }));
+
+        let left = WindowExactF64Score::from_f64(f64::from_bits(1));
+        let right = WindowExactF64Score::from_f64(f64::MAX);
+        let fallback = <WindowExactF64Score as vf2::Vf2Score>::combine(&left, &right);
+        let arbitrary = <ExactF64Score as vf2::Vf2Score>::combine(
+            &ExactF64Score::from_f64(f64::from_bits(1)),
+            &ExactF64Score::from_f64(f64::MAX),
+        );
+        assert!(matches!(fallback, WindowExactF64Score::Wide(_)));
+        assert_eq!(
+            fallback.to_biguint().as_ref(),
+            arbitrary_as_biguint(&arbitrary)
+        );
+    }
+
+    #[test]
+    fn window_repeated_accumulation_and_infinity_are_exact() {
+        let value = f64::from_bits((1u64 << 52) - 1);
+        let leaf = WindowExactF64Score::from_f64(value);
+        let arbitrary_leaf = ExactF64Score::from_f64(value);
+        let mut window = <WindowExactF64Score as vf2::Vf2Score>::id();
+        let mut arbitrary = <ExactF64Score as vf2::Vf2Score>::id();
+        for _ in 0..4097 {
+            window = <WindowExactF64Score as vf2::Vf2Score>::combine(&window, &leaf);
+            arbitrary = <ExactF64Score as vf2::Vf2Score>::combine(&arbitrary, &arbitrary_leaf);
+        }
+        assert_eq!(
+            window.to_biguint().as_ref(),
+            arbitrary_as_biguint(&arbitrary)
+        );
+        let infinity = WindowExactF64Score::from_f64(f64::INFINITY);
+        assert!(infinity > window);
+        assert_eq!(
+            <WindowExactF64Score as vf2::Vf2Score>::combine(&infinity, &window),
+            infinity
+        );
+    }
+
+    #[test]
+    fn r184_counters_and_object_width_expose_the_window_boundary() {
+        r182_reset_counters();
+        let left = R184InstrumentedWindowExactF64Score::from_f64(0.1);
+        let right = R184InstrumentedWindowExactF64Score::from_f64(0.2);
+        let sum = R184InstrumentedWindowExactF64Score::combine(&left, &right);
+        let _ = Ord::cmp(&sum, &left);
+        let counters = r182_take_counters();
+
+        assert_eq!(counters.leaf_construction_count, 2);
+        assert_eq!(counters.r184_combine_count, 1);
+        assert_eq!(counters.r184_compare_count, 1);
+        assert_eq!(counters.r184_compact_result_count, 3);
+        assert_eq!(counters.r184_fallback_transition_count, 0);
+        assert_eq!(counters.r184_wide_combine_count, 0);
+        assert!(counters.r184_maximum_window_limb_count <= WINDOW_EXACT_F64_LIMBS as u64);
+        assert!(
+            std::mem::size_of::<WindowExactF64Score>()
+                < std::mem::size_of::<PrefixInitializedExactF64Score>()
+        );
+    }
