+impl vf2::Vf2Score for R183InstrumentedPrefixInitializedExactF64Score {
+    fn combine(left: &Self, right: &Self) -> Self {
+        let (left_used, right_used) = match (&left.0, &right.0) {
+            (
+                PrefixInitializedExactF64Score::Finite {
+                    used: left_used, ..
+                },
+                PrefixInitializedExactF64Score::Finite {
+                    used: right_used, ..
+                },
+            ) => (usize::from(*left_used), usize::from(*right_used)),
+            _ => (0, 0),
+        };
+        let score = <PrefixInitializedExactF64Score as vf2::Vf2Score>::combine(&left.0, &right.0);
+        let used = match &score {
+            PrefixInitializedExactF64Score::Finite { used, .. } => usize::from(*used),
+            PrefixInitializedExactF64Score::PositiveInfinity => 0,
+        };
+        r182_update_counters(|counters| {
+            counters.r183_destination_initialized_limb_count += used as u64;
+            counters.arithmetic_limb_visit_count += left_used.max(right_used) as u64;
+            counters.carry_extension_count += u64::from(used > left_used.max(right_used));
+            counters.maximum_used_limb_count = counters.maximum_used_limb_count.max(used as u64);
+        });
+        Self(score)
+    }
+
+    fn id() -> Self {
+        Self(<PrefixInitializedExactF64Score as vf2::Vf2Score>::id())
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        if let (
+            PrefixInitializedExactF64Score::Finite {
+                limbs: left_limbs,
+                used: left_used,
+            },
+            PrefixInitializedExactF64Score::Finite {
+                limbs: right_limbs,
+                used: right_used,
+            },
+        ) = (&left.0, &right.0)
+        {
+            let visits = if left_used == right_used {
+                let upper = usize::from(*left_used);
+                (0..upper)
+                    .rev()
+                    .position(|index| {
+                        PrefixInitializedExactF64Score::finite_limb(left_limbs, *left_used, index)
+                            != PrefixInitializedExactF64Score::finite_limb(
+                                right_limbs,
+                                *right_used,
+                                index,
+                            )
+                    })
+                    .map_or(upper, |index| index + 1)
+            } else {
+                0
+            } as u64;
+            r182_update_counters(|counters| counters.comparison_limb_visit_count += visits);
+        }
+        left.0.cmp(&right.0)
+    }
+}
