-            .edges_connecting(node_map(edge.source()), node_map(edge.target()))
-            .next()?
-            .weight();
-        score = W::Score::combine(
-            &score,
-            &scorer
-                .score(needle, haystack)
-                .expect("error is infallible")?,
-        );
+    Some(score)
+}
