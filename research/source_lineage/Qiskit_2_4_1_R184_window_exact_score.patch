+#[cfg(test)]
+mod r182_score_cost_counter_tests {
+    use super::*;
+
+    #[test]
+    fn fixed_and_active_counters_expose_the_full_width_initialization_gap() {
+        r182_reset_counters();
+        let fixed_left = R182InstrumentedFixedExactF64Score::from_f64(0.1);
+        let fixed_right = R182InstrumentedFixedExactF64Score::from_f64(0.2);
+        let fixed_sum = R182InstrumentedFixedExactF64Score::combine(&fixed_left, &fixed_right);
+        let _ = Ord::cmp(&fixed_sum, &fixed_left);
+        let fixed = r182_take_counters();
+
+        r182_reset_counters();
+        let active_left = R182InstrumentedActiveFixedExactF64Score::from_f64(0.1);
+        let active_right = R182InstrumentedActiveFixedExactF64Score::from_f64(0.2);
+        let active_sum =
+            R182InstrumentedActiveFixedExactF64Score::combine(&active_left, &active_right);
+        let _ = Ord::cmp(&active_sum, &active_left);
+        let active = r182_take_counters();
+
+        assert_eq!(fixed.leaf_construction_count, 2);
+        assert_eq!(active.leaf_construction_count, 2);
+        assert_eq!(fixed.destination_zeroed_limb_count, 3 * 34);
+        assert_eq!(active.destination_zeroed_limb_count, 3 * 34);
+        assert_eq!(fixed.arithmetic_limb_visit_count, 34);
+        assert!(active.arithmetic_limb_visit_count < fixed.arithmetic_limb_visit_count);
+        assert_eq!(fixed.biguint_heap_allocation_count, 0);
+        assert_eq!(active.biguint_heap_allocation_count, 0);
+    }
+
+    #[test]
+    fn biguint_scope_records_real_allocator_events() {
+        r182_reset_counters();
+        let left = R182InstrumentedExactF64Score::from_f64(0.1);
+        let right = R182InstrumentedExactF64Score::from_f64(0.2);
+        let sum = R182InstrumentedExactF64Score::combine(&left, &right);
+        let _ = Ord::cmp(&sum, &left);
+        let counters = r182_take_counters();
+
+        assert_eq!(counters.leaf_construction_count, 2);
+        assert_eq!(counters.destination_zeroed_limb_count, 0);
+        assert!(counters.arithmetic_limb_visit_count > 0);
+        assert!(counters.comparison_limb_visit_count > 0);
+        assert!(counters.maximum_used_limb_count > 0);
+        assert!(counters.biguint_heap_allocation_count > 0);
+        assert!(counters.biguint_heap_allocated_bytes > 0);
+    }
+}
