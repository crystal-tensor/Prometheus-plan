+// R162 keeps a compact, source-local witness of score formation.  The labels
+// are carried by the graph weights so the trace can reconstruct partial
+// candidate mappings without changing the production f64 path.
+type ScoreTraceEvent = (String, u64, u64, u64, String, String, String);
+
+#[derive(Clone)]
+struct TraceScore {
+    value: f64,
+    terms: String,
+    leaves: Vec<(String, u64)>,
+    events: Option<Rc<RefCell<Vec<ScoreTraceEvent>>>>,
+}
+
+fn encode_score_leaves(leaves: &[(String, u64)]) -> String {
+    leaves
+        .iter()
+        .map(|(label, bits)| format!("{}={}", label, bits))
+        .collect::<Vec<_>>()
+        .join(";")
+}
+
+impl TraceScore {
+    fn leaf(value: f64, terms: String, events: Rc<RefCell<Vec<ScoreTraceEvent>>>) -> Self {
+        let leaves = vec![(terms.clone(), value.to_bits())];
+        Self {
+            value,
+            terms,
+            leaves,
+            events: Some(events),
+        }
+    }
+
+    fn zero(events: Rc<RefCell<Vec<ScoreTraceEvent>>>) -> Self {
+        Self {
+            value: 0.0,
+            terms: String::new(),
+            leaves: Vec::new(),
+            events: Some(events),
+        }
+    }
+}
+
+impl vf2::Vf2Score for TraceScore {
+    fn combine(left: &Self, right: &Self) -> Self {
+        let value = left.value + right.value;
+        let terms = match (left.terms.is_empty(), right.terms.is_empty()) {
+            (true, true) => String::new(),
+            (true, false) => right.terms.clone(),
+            (false, true) => left.terms.clone(),
+            (false, false) => format!("{}|{}", left.terms, right.terms),
+        };
+        let mut leaves = left.leaves.clone();
+        leaves.extend(right.leaves.iter().cloned());
+        let events = left.events.clone().or_else(|| right.events.clone());
+        if let Some(events_ref) = &events {
+            events_ref.borrow_mut().push((
+                "combine".to_string(),
+                left.value.to_bits(),
+                right.value.to_bits(),
+                value.to_bits(),
+                left.terms.clone(),
+                right.terms.clone(),
+                encode_score_leaves(&leaves),
+            ));
+        }
+        Self {
+            value,
+            terms,
+            leaves,
+            events,
+        }
+    }
+
+    fn id() -> Self {
+        Self {
+            value: 0.0,
+            terms: String::new(),
+            leaves: Vec::new(),
+            events: None,
+        }
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        let ordering = left
+            .value
+            .partial_cmp(&right.value)
+            .expect("trace scores must not return nan");
+        if let Some(events_ref) = left.events.as_ref().or(right.events.as_ref()) {
+            let code = match ordering {
+                std::cmp::Ordering::Less => 0,
+                std::cmp::Ordering::Equal => 1,
+                std::cmp::Ordering::Greater => 2,
+            };
+            events_ref.borrow_mut().push((
+                "compare".to_string(),
+                left.value.to_bits(),
+                right.value.to_bits(),
+                code,
+                left.terms.clone(),
+                right.terms.clone(),
+                String::new(),
+            ));
+        }
+        ordering
+    }
+}
