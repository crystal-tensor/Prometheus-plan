+                .with_restriction(vf2::Restriction::Decreasing(best_score))
+                .with_vf2pp_ordering();
+            if let Some(mapping) = minimize_vf2(vf2, config) {
+                let mapping = mapping
+                    .iter()
+                    .map(|(k, v)| (interactions.nodes[k.index()], coupling_qubits[v.index()]))
+                    .collect();
+                match map_free_qubits(num_physical_qubits, interactions, mapping, avg_error_map) {
+                    Some(mapping) => Vf2PassReturn::Solution(mapping),
+                    None => Vf2PassReturn::NoSolution,
+                }
+            } else if had_best_score {
+                Vf2PassReturn::NoImprovement
+            } else {
+                Vf2PassReturn::NoSolution
+            }
+        } else {
+            Vf2PassReturn::NoSolution
+        }
+    } else {
+        Vf2PassReturn::NoSolution
+    };
+    Ok((output, counter_vector(r182_take_counters())))
+}
