+#[derive(Clone, Debug, Eq, Ord, PartialEq, PartialOrd)]
+enum ExactF64Score {
+    Finite(BigUint),
+    PositiveInfinity,
+}
+
+impl ExactF64Score {
+    fn from_f64(value: f64) -> Self {
+        assert!(!value.is_nan(), "exact VF2 scores must not be NaN");
+        assert!(value >= 0.0, "exact VF2 scores must not be negative");
+        if value.is_infinite() {
+            return Self::PositiveInfinity;
+        }
+        if value == 0.0 {
+            return Self::Finite(BigUint::from(0u8));
+        }
+        let bits = value.to_bits();
+        let exponent = ((bits >> 52) & 0x7ff) as usize;
+        let fraction = bits & ((1u64 << 52) - 1);
+        let coefficient = if exponent == 0 {
+            BigUint::from(fraction)
+        } else {
+            BigUint::from((1u64 << 52) | fraction) << (exponent - 1)
+        };
+        Self::Finite(coefficient)
+    }
+}
+
+impl vf2::Vf2Score for ExactF64Score {
+    fn combine(left: &Self, right: &Self) -> Self {
+        match (left, right) {
+            (Self::Finite(left), Self::Finite(right)) => Self::Finite(left + right),
+            _ => Self::PositiveInfinity,
+        }
+    }
+
+    fn id() -> Self {
+        Self::Finite(BigUint::from(0u8))
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        left.cmp(right)
+    }
+}
+
+// A finite binary64 value is an integer multiple of 2^-1074. The largest
+// finite coefficient occupies bits 0..=2097 on that grid. Thirty-four limbs
+// leave 78 carry bits, enough to sum more leaves than a <=64-bit usize can
+// address without heap allocation in the VF2 scoring loop.
+const FIXED_EXACT_F64_LIMBS: usize = 34;
+const _: () = assert!(usize::BITS <= 64);
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+enum FixedExactF64Score {
+    Finite([u64; FIXED_EXACT_F64_LIMBS]),
+    PositiveInfinity,
+}
+
+impl FixedExactF64Score {
+    fn from_f64(value: f64) -> Self {
+        assert!(!value.is_nan(), "exact VF2 scores must not be NaN");
+        assert!(value >= 0.0, "exact VF2 scores must not be negative");
+        if value.is_infinite() {
+            return Self::PositiveInfinity;
+        }
+
+        let mut limbs = [0u64; FIXED_EXACT_F64_LIMBS];
+        if value == 0.0 {
+            return Self::Finite(limbs);
+        }
+
+        let bits = value.to_bits();
+        let exponent = ((bits >> 52) & 0x7ff) as usize;
+        let fraction = bits & ((1u64 << 52) - 1);
+        let coefficient = if exponent == 0 {
+            fraction
+        } else {
+            (1u64 << 52) | fraction
+        };
+        let shift = exponent.saturating_sub(1);
+        let limb = shift / u64::BITS as usize;
+        let offset = shift % u64::BITS as usize;
+        limbs[limb] = coefficient << offset;
+        if offset != 0 {
+            limbs[limb + 1] = coefficient >> (u64::BITS as usize - offset);
+        }
+        Self::Finite(limbs)
+    }
+}
+
+impl Ord for FixedExactF64Score {
+    fn cmp(&self, other: &Self) -> std::cmp::Ordering {
+        match (self, other) {
+            (Self::PositiveInfinity, Self::PositiveInfinity) => std::cmp::Ordering::Equal,
+            (Self::PositiveInfinity, _) => std::cmp::Ordering::Greater,
+            (_, Self::PositiveInfinity) => std::cmp::Ordering::Less,
+            (Self::Finite(left), Self::Finite(right)) => {
+                for index in (0..FIXED_EXACT_F64_LIMBS).rev() {
+                    match left[index].cmp(&right[index]) {
+                        std::cmp::Ordering::Equal => {}
+                        ordering => return ordering,
+                    }
+                }
+                std::cmp::Ordering::Equal
+            }
+        }
+    }
+}
+
+impl PartialOrd for FixedExactF64Score {
+    fn partial_cmp(&self, other: &Self) -> Option<std::cmp::Ordering> {
+        Some(self.cmp(other))
+    }
+}
+
+impl vf2::Vf2Score for FixedExactF64Score {
+    fn combine(left: &Self, right: &Self) -> Self {
+        match (left, right) {
+            (Self::Finite(left), Self::Finite(right)) => {
+                let mut limbs = [0u64; FIXED_EXACT_F64_LIMBS];
+                let mut carry = false;
+                for index in 0..FIXED_EXACT_F64_LIMBS {
+                    let (partial, left_overflow) = left[index].overflowing_add(right[index]);
+                    let (sum, carry_overflow) = partial.overflowing_add(u64::from(carry));
+                    limbs[index] = sum;
+                    carry = left_overflow || carry_overflow;
+                }
+                assert!(
+                    !carry,
+                    "fixed exact VF2 score exceeded its address-space bound"
+                );
+                Self::Finite(limbs)
+            }
+            _ => Self::PositiveInfinity,
+        }
+    }
+
+    fn id() -> Self {
+        Self::Finite([0u64; FIXED_EXACT_F64_LIMBS])
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        left.cmp(right)
+    }
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+enum ActiveFixedExactF64Score {
+    Finite {
+        limbs: [u64; FIXED_EXACT_F64_LIMBS],
+        used: u8,
+    },
+    PositiveInfinity,
+}
+
+impl ActiveFixedExactF64Score {
+    fn from_f64(value: f64) -> Self {
+        assert!(!value.is_nan(), "exact VF2 scores must not be NaN");
+        assert!(value >= 0.0, "exact VF2 scores must not be negative");
+        if value.is_infinite() {
+            return Self::PositiveInfinity;
+        }
+
+        let mut limbs = [0u64; FIXED_EXACT_F64_LIMBS];
+        if value == 0.0 {
+            return Self::Finite { limbs, used: 0 };
+        }
+
+        let bits = value.to_bits();
+        let exponent = ((bits >> 52) & 0x7ff) as usize;
+        let fraction = bits & ((1u64 << 52) - 1);
+        let coefficient = if exponent == 0 {
+            fraction
+        } else {
+            (1u64 << 52) | fraction
+        };
+        let shift = exponent.saturating_sub(1);
+        let limb = shift / u64::BITS as usize;
+        let offset = shift % u64::BITS as usize;
+        limbs[limb] = coefficient << offset;
+        let mut used = limb + 1;
+        if offset != 0 {
+            let spill = coefficient >> (u64::BITS as usize - offset);
+            if spill != 0 {
+                limbs[limb + 1] = spill;
+                used += 1;
+            }
+        }
+        Self::Finite {
+            limbs,
+            used: used as u8,
+        }
+    }
+}
+
+impl Ord for ActiveFixedExactF64Score {
+    fn cmp(&self, other: &Self) -> std::cmp::Ordering {
+        match (self, other) {
+            (Self::PositiveInfinity, Self::PositiveInfinity) => std::cmp::Ordering::Equal,
+            (Self::PositiveInfinity, _) => std::cmp::Ordering::Greater,
+            (_, Self::PositiveInfinity) => std::cmp::Ordering::Less,
+            (
+                Self::Finite {
+                    limbs: left,
+                    used: left_used,
+                },
+                Self::Finite {
+                    limbs: right,
+                    used: right_used,
+                },
+            ) => match left_used.cmp(right_used) {
+                std::cmp::Ordering::Equal => {
+                    for index in (0..usize::from(*left_used)).rev() {
+                        match left[index].cmp(&right[index]) {
+                            std::cmp::Ordering::Equal => {}
+                            ordering => return ordering,
+                        }
+                    }
+                    std::cmp::Ordering::Equal
+                }
+                ordering => ordering,
+            },
+        }
+    }
+}
+
+impl PartialOrd for ActiveFixedExactF64Score {
+    fn partial_cmp(&self, other: &Self) -> Option<std::cmp::Ordering> {
+        Some(self.cmp(other))
+    }
+}
+
+impl vf2::Vf2Score for ActiveFixedExactF64Score {
+    fn combine(left: &Self, right: &Self) -> Self {
+        match (left, right) {
+            (
+                Self::Finite {
+                    limbs: left,
+                    used: left_used,
+                },
+                Self::Finite {
+                    limbs: right,
+                    used: right_used,
+                },
+            ) => {
+                let mut limbs = [0u64; FIXED_EXACT_F64_LIMBS];
+                let active = usize::from((*left_used).max(*right_used));
+                let mut carry = false;
+                for index in 0..active {
+                    let (partial, left_overflow) = left[index].overflowing_add(right[index]);
+                    let (sum, carry_overflow) = partial.overflowing_add(u64::from(carry));
+                    limbs[index] = sum;
+                    carry = left_overflow || carry_overflow;
+                }
+                let used = if carry {
+                    assert!(
+                        active < FIXED_EXACT_F64_LIMBS,
+                        "active fixed exact VF2 score exceeded its address-space bound"
+                    );
+                    limbs[active] = 1;
+                    active + 1
+                } else {
+                    active
+                };
+                Self::Finite {
+                    limbs,
+                    used: used as u8,
+                }
+            }
+            _ => Self::PositiveInfinity,
+        }
+    }
+
+    fn id() -> Self {
+        Self::Finite {
+            limbs: [0u64; FIXED_EXACT_F64_LIMBS],
+            used: 0,
+        }
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        left.cmp(right)
+    }
+}
+
+// R162 keeps a compact, source-local witness of score formation.  The labels
+// are carried by the graph weights so the trace can reconstruct partial
+// candidate mappings without changing the production f64 path.
+type ScoreTraceEvent = (String, u64, u64, u64, String, String, String);
+
+#[derive(Clone)]
+struct TraceScore {
+    value: f64,
+    terms: String,
+    leaves: Vec<(String, u64)>,
+    events: Option<Rc<RefCell<Vec<ScoreTraceEvent>>>>,
+}
+
+fn encode_score_leaves(leaves: &[(String, u64)]) -> String {
+    leaves
+        .iter()
+        .map(|(label, bits)| format!("{}={}", label, bits))
+        .collect::<Vec<_>>()
+        .join(";")
+}
+
+impl TraceScore {
+    fn leaf(value: f64, terms: String, events: Rc<RefCell<Vec<ScoreTraceEvent>>>) -> Self {
+        let leaves = vec![(terms.clone(), value.to_bits())];
+        Self {
+            value,
+            terms,
+            leaves,
+            events: Some(events),
+        }
+    }
+
+    fn zero(events: Rc<RefCell<Vec<ScoreTraceEvent>>>) -> Self {
+        Self {
+            value: 0.0,
+            terms: String::new(),
+            leaves: Vec::new(),
+            events: Some(events),
+        }
+    }
+}
+
+impl vf2::Vf2Score for TraceScore {
+    fn combine(left: &Self, right: &Self) -> Self {
+        let value = left.value + right.value;
+        let terms = match (left.terms.is_empty(), right.terms.is_empty()) {
+            (true, true) => String::new(),
+            (true, false) => right.terms.clone(),
+            (false, true) => left.terms.clone(),
+            (false, false) => format!("{}|{}", left.terms, right.terms),
+        };
+        let mut leaves = left.leaves.clone();
+        leaves.extend(right.leaves.iter().cloned());
+        let events = left.events.clone().or_else(|| right.events.clone());
+        if let Some(events_ref) = &events {
+            events_ref.borrow_mut().push((
+                "combine".to_string(),
+                left.value.to_bits(),
+                right.value.to_bits(),
+                value.to_bits(),
+                left.terms.clone(),
+                right.terms.clone(),
+                encode_score_leaves(&leaves),
+            ));
+        }
+        Self {
+            value,
+            terms,
+            leaves,
+            events,
+        }
+    }
+
+    fn id() -> Self {
+        Self {
+            value: 0.0,
+            terms: String::new(),
+            leaves: Vec::new(),
+            events: None,
+        }
+    }
+
+    fn cmp(left: &Self, right: &Self) -> std::cmp::Ordering {
+        let ordering = left
+            .value
+            .partial_cmp(&right.value)
+            .expect("trace scores must not return nan");
+        if let Some(events_ref) = left.events.as_ref().or(right.events.as_ref()) {
+            let code = match ordering {
+                std::cmp::Ordering::Less => 0,
+                std::cmp::Ordering::Equal => 1,
+                std::cmp::Ordering::Greater => 2,
+            };
+            events_ref.borrow_mut().push((
+                "compare".to_string(),
+                left.value.to_bits(),
+                right.value.to_bits(),
+                code,
+                left.terms.clone(),
+                right.terms.clone(),
+                String::new(),
+            ));
+        }
+        ordering
+    }
+}
+
