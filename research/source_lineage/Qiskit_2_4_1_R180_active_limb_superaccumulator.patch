+#[cfg(test)]
+mod r180_active_fixed_exact_score_tests {
+    use super::*;
+
+    fn active_as_biguint(score: &ActiveFixedExactF64Score) -> Option<BigUint> {
+        match score {
+            ActiveFixedExactF64Score::PositiveInfinity => None,
+            ActiveFixedExactF64Score::Finite { limbs, used } => {
+                Some(limbs[..usize::from(*used)].iter().enumerate().fold(
+                    BigUint::from(0u8),
+                    |sum, (index, limb)| {
+                        sum + (BigUint::from(*limb) << (index * u64::BITS as usize))
+                    },
+                ))
+            }
+        }
+    }
+
+    fn arbitrary_as_biguint(score: &ExactF64Score) -> Option<&BigUint> {
+        match score {
+            ExactF64Score::PositiveInfinity => None,
+            ExactF64Score::Finite(value) => Some(value),
+        }
+    }
+
+    #[test]
+    fn active_binary64_decode_matches_biguint() {
+        let samples = [
+            0.0,
+            -0.0,
+            f64::from_bits(1),
+            f64::from_bits((1u64 << 52) - 1),
+            f64::MIN_POSITIVE,
+            0.1,
+            1.0,
+            f64::MAX,
+        ];
+        for value in samples {
+            let active = ActiveFixedExactF64Score::from_f64(value);
+            let arbitrary = ExactF64Score::from_f64(value);
+            assert_eq!(
+                active_as_biguint(&active).as_ref(),
+                arbitrary_as_biguint(&arbitrary)
+            );
+        }
+    }
+
+    #[test]
+    fn active_addition_and_order_match_biguint() {
+        let values = [f64::from_bits(1), 0.1, 0.2, 0.3, 1.0, f64::MAX];
+        for left_value in values {
+            for right_value in values {
+                let active_left = ActiveFixedExactF64Score::from_f64(left_value);
+                let active_right = ActiveFixedExactF64Score::from_f64(right_value);
+                let active_sum = <ActiveFixedExactF64Score as vf2::Vf2Score>::combine(
+                    &active_left,
+                    &active_right,
+                );
+                let arbitrary_left = ExactF64Score::from_f64(left_value);
+                let arbitrary_right = ExactF64Score::from_f64(right_value);
+                let arbitrary_sum =
+                    <ExactF64Score as vf2::Vf2Score>::combine(&arbitrary_left, &arbitrary_right);
+                assert_eq!(
+                    active_as_biguint(&active_sum).as_ref(),
+                    arbitrary_as_biguint(&arbitrary_sum)
+                );
+                assert_eq!(
+                    active_left.cmp(&active_right),
+                    arbitrary_left.cmp(&arbitrary_right)
+                );
+            }
+        }
+    }
+
+    #[test]
+    fn active_length_tracks_carry_and_zero() {
+        assert!(matches!(
+            ActiveFixedExactF64Score::from_f64(0.0),
+            ActiveFixedExactF64Score::Finite { used: 0, .. }
+        ));
+        let largest_subnormal = f64::from_bits((1u64 << 52) - 1);
+        let left = ActiveFixedExactF64Score::from_f64(largest_subnormal);
+        let sum = <ActiveFixedExactF64Score as vf2::Vf2Score>::combine(&left, &left);
+        assert_eq!(
+            active_as_biguint(&sum),
+            Some(BigUint::from((1u64 << 53) - 2))
+        );
+    }
+
+    #[test]
+    fn infinity_is_larger_than_every_active_finite_score() {
+        let infinity = ActiveFixedExactF64Score::from_f64(f64::INFINITY);
+        let maximum = ActiveFixedExactF64Score::from_f64(f64::MAX);
+        assert!(infinity > maximum);
+        assert_eq!(
+            <ActiveFixedExactF64Score as vf2::Vf2Score>::combine(&infinity, &maximum),
+            infinity
+        );
+    }
