+fn trace_graph_from_interactions(graph: &Graph<usize, usize>) -> Graph<TraceWeight, TraceWeight> {
+    let mut out = Graph::with_capacity(graph.node_count(), graph.edge_count());
+    for node in graph.node_indices() {
+        out.add_node(TraceWeight {
+            value: *graph.node_weight(node).expect("interaction node exists") as f64,
+            label: format!("v{}", node.index()),
+        });
+    }
+    for edge in graph.edge_references() {
+        out.add_edge(
+            edge.source(),
+            edge.target(),
+            TraceWeight {
+                value: *edge.weight() as f64,
+                label: format!("v{}->v{}", edge.source().index(), edge.target().index()),
+            },
+        );
+    }
+    out
+}
